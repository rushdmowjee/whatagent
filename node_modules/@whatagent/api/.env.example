# WhatAgent API — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/whatagent

# Security — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# Meta App
META_APP_SECRET=your-meta-app-secret-here

# Webhook verification token (set this in Meta app dashboard too)
WEBHOOK_VERIFY_TOKEN=whatagent_verify_2024

# Server
PORT=3000
CORS_ORIGIN=*
