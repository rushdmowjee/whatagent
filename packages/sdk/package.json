{
  "name": "whatagent",
  "version": "1.0.0",
  "description": "The easiest way to send WhatsApp messages from code.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["whatsapp", "messaging", "api", "sdk"],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.2",
    "tsup": "^8.0.1",
    "@types/node": "^20.10.0"
  }
}
