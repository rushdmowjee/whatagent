{
  "name": "whatagent",
  "version": "0.1.0",
  "description": "The easiest way to send WhatsApp messages from code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc && npm run build --workspace=packages/mcp",
    "build:sdk": "tsc",
    "build:mcp": "npm run build --workspace=packages/mcp",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dev": "tsc --watch",
    "send": "node dist/send.js"
  },
  "keywords": ["whatsapp", "messaging", "sdk", "api"],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  }
}
